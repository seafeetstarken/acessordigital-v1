rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isSelf(docId) {
      return isSignedIn() && request.auth.uid == docId;
    }

    function canReadWorkspace(workspaceId) {
      return isSignedIn();
    }

    function canWriteWorkspace(workspaceId) {
      return isOwner();
    }

    match /workspaces/{workspaceId} {
      allow read: if canReadWorkspace(workspaceId);
      allow write: if canWriteWorkspace(workspaceId) || isSelf(workspaceId);
    }

    match /users/{userId} {
      allow read, create, update: if isSelf(userId) || isOwner();
      allow delete: if isOwner();
    }

    match /contacts/{contactId} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }

    match /conversations/{conversationId} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }

    match /deals/{dealId} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }

    match /automations/{automationId} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }

    match /knowledge_base/{documentId} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }

    match /session_notes/{noteId} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }

    match /changelog_events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }
  }
}
